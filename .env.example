# ── Безопасность ──────────────────────────────────────────────
# Сгенерируй свой ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=замени-на-случайную-строку-50-символов

DEBUG=False

# Через запятую — домены где будет работать бэк
ALLOWED_HOSTS=твой-домен.com,www.твой-домен.com

# ── База данных ────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=konoq
DB_USER=konoq
DB_PASSWORD=придумай-пароль
DB_HOST=db
DB_PORT=5432

# ── CORS — откуда фронт будет слать запросы ───────────────────
CORS_ALLOWED_ORIGINS=https://твой-домен.com,https://www.твой-домен.com

# ── JWT ────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_HOURS=8
REFRESH_TOKEN_LIFETIME_DAYS=30

# ── WhatsApp Bot (Meta Cloud API) ────────────────────────────
WA_TOKEN=токен-из-meta-business
WA_PHONE_NUMBER_ID=phone-number-id-из-whatsapp-api
WA_VERIFY_TOKEN=произвольная-строка-для-верификации
